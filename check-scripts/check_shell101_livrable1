#!/bin/sh
# Validate delivery archive on host share (content fingerprint, not raw tar bytes).
set -eu
. "$(dirname "$0")/_common.sh"

ARCHIVE="/mnt/host/.delivery_101.tar"
EXP_CONTENT_MD5="189e15d024987af4682d4b5ff4c6fa7e"

if [ ! -f "$ARCHIVE" ]; then
	err "Archive introuvable : $ARCHIVE (copiez .delivery_101.tar dans /mnt/host)"
	exit 1
fi

GOT_MEMBERS=$(tar -tf "$ARCHIVE" 2>/dev/null | sed 's|^\./||' | LC_ALL=C sort | tr -d '\r')
EXP_MEMBERS=$(printf '%s\n' \
	'101/' \
	'101/links/' \
	'101/links/ubuntu' \
	'101/links/wikipedia_linux' \
	'101/memos/' \
	'101/memos/memo1.txt' \
	'101/memos/memo2.txt' \
	'101/secret1.txt' \
	'101/secret2.txt' \
	'101/works/' \
	'101/works/essay2.txt')

if [ "$GOT_MEMBERS" != "$EXP_MEMBERS" ]; then
	err "Contenu de l'archive incorrect (tar -tf). Vérifiez le dossier 101 archivé après rm/nano/mv."
	exit 1
fi

TMP=$(mktemp -d)
trap 'rm -rf "$TMP"' EXIT INT HUP TERM

if ! tar -xf "$ARCHIVE" -C "$TMP" 2>/dev/null; then
	err "Impossible d'extraire $ARCHIVE"
	exit 1
fi

if [ ! -d "$TMP/101" ]; then
	err "L'archive ne contient pas le répertoire 101/"
	exit 1
fi

GOT_MD5=$(cd "$TMP" && find 101 -type f -print0 | sort -z | xargs -0 md5sum 2>/dev/null | LC_ALL=C sort | md5sum | awk '{print $1}')

if [ "$GOT_MD5" != "$EXP_CONTENT_MD5" ]; then
	err "Contenu des fichiers dans l'archive incorrect (empreinte md5)."
	exit 1
fi

ok "$EXP_CONTENT_MD5"
